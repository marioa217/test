<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_sgr" model="ir.ui.view">
        <field name="name">product.template.form.inherit.pos_romania_sgr</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']//group[@name='group_general']/field[@name='type']" position="after">
                <field name="is_sgr_applicable"/>
            </xpath>
        </field>
    </record>
</odoo>

