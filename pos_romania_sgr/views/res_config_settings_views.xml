<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_pos_romania_sgr" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_romania_sgr</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='point_of_sale']//block[@id='product_and_category_block']" position="inside">
                <setting id="pos_sgr_fee_product" string="SGR Fee Product" help="Select the product that will be added automatically as the SGR (Guarantee-Return System) fee when applicable products are added in POS.">
                    <field name="pos_sgr_product_id" options="{'no_open': True}"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>

