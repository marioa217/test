<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_saga_export_wizard" model="ir.ui.view">
        <field name="name">pos.order.saga.export.wizard.form</field>
        <field name="model">pos.order.saga.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Saga XML">
                <group>
                    <field name="order_ids" invisible="1"/>
                    <field name="order_count" readonly="1"/>
                    <field name="company_id" readonly="1"/>
                    <field name="date_format"/>
                    <field name="anonymous_client_name"/>
                    <field name="include_receipts"/>
                </group>
                <group>
                    <div colspan="2">
                        This export creates Saga Facturi XML from paid POS orders.
                        If receipt export is enabled, Odoo also adds Saga Incasari XML grouped by payment date.
                        Make sure each POS payment method has a Saga Treasury Account before exporting receipts.
                    </div>
                </group>
                <footer>
                    <button name="action_export" type="object" string="Export" class="btn-primary" default_focus="1"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_order_saga_export_server" model="ir.actions.server">
        <field name="name">Export Saga XML</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_saga_export_wizard()</field>
        <field name="group_ids" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="view_pos_order_form_saga_export" model="ir.ui.view">
        <field name="name">pos.order.form.saga.export</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_saga_export_wizard"
                    type="object"
                    string="Saga XML"
                    groups="point_of_sale.group_pos_user"
                    invisible="state not in ['paid', 'done'] or is_refund or amount_total &lt; 0"
                />
            </xpath>
        </field>
    </record>

    <record id="view_pos_payment_method_form_saga_export" model="ir.ui.view">
        <field name="name">pos.payment.method.form.saga.export</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="saga_treasury_account" placeholder="5311.00001 or 5121.00002"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_payment_method_tree_saga_export" model="ir.ui.view">
        <field name="name">pos.payment.method.list.saga.export</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="saga_treasury_account" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
