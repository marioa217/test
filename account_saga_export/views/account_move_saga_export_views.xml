<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_saga_export_wizard" model="ir.ui.view">
        <field name="name">account.move.saga.export.wizard.form</field>
        <field name="model">account.move.saga.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Saga XML">
                <group>
                    <field name="move_ids" invisible="1"/>
                    <field name="invoice_count" readonly="1"/>
                    <field name="company_id" readonly="1"/>
                    <field name="date_format"/>
                </group>
                <group>
                    <div colspan="2">
                        This first version exports posted customer invoices and vendor bills in Saga's XML invoice format.
                        If you selected more than one invoice, Odoo will download a ZIP file with one XML file per invoice.
                    </div>
                </group>
                <footer>
                    <button name="action_export" type="object" string="Export" class="btn-primary" default_focus="1"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_saga_export_server" model="ir.actions.server">
        <field name="name">Export Saga XML</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_saga_export_wizard()</field>
        <field name="group_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>

    <record id="view_move_form_saga_export" model="ir.ui.view">
        <field name="name">account.move.form.saga.export</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_saga_export_wizard"
                    type="object"
                    string="Saga XML"
                    groups="account.group_account_invoice"
                    invisible="state != 'posted' or move_type not in ('out_invoice', 'in_invoice')"
                />
            </xpath>
        </field>
    </record>
</odoo>
