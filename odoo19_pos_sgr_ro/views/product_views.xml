<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_sgr" model="ir.ui.view">
        <field name="name">product.template.form.sgr.ro</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sales']" position="after">
                <group string="Romania SGR">
                    <field name="sgr_enabled"/>
                    <field name="sgr_material" invisible="not sgr_enabled"/>
                    <field name="sgr_value" invisible="not sgr_enabled"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
