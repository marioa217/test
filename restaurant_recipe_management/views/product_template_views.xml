<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_restaurant_recipe" model="ir.ui.view">
        <field name="name">product.template.form.restaurant.recipe</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_documents']" position="before">
                <button
                    name="action_open_restaurant_recipe"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-cutlery"
                    invisible="type != 'consu' or not sale_ok"
                >
                    <field name="recipe_count" widget="statinfo" string="Recipe"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='type']" position="after">
                <field name="is_recipe_managed" invisible="type != 'consu' or not sale_ok"/>
                <field name="recipe_theoretical_cost" readonly="1" invisible="not is_recipe_managed" widget="monetary" options="{'currency_field': 'currency_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
