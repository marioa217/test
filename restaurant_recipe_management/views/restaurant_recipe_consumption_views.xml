<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_recipe_consumption_list" model="ir.ui.view">
        <field name="name">restaurant.recipe.consumption.list</field>
        <field name="model">restaurant.recipe.consumption</field>
        <field name="arch" type="xml">
            <list string="Recipe Consumption Logs">
                <field name="processed_at"/>
                <field name="operation_type"/>
                <field name="state"/>
                <field name="pos_order_id"/>
                <field name="sold_product_id"/>
                <field name="sold_qty"/>
                <field name="recipe_cost_snapshot"/>
                <field name="source_location_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_restaurant_recipe_consumption_form" model="ir.ui.view">
        <field name="name">restaurant.recipe.consumption.form</field>
        <field name="model">restaurant.recipe.consumption</field>
        <field name="arch" type="xml">
            <form string="Recipe Consumption Log" delete="false">
                <header>
                    <button
                        name="action_open_rrm_reprocess_wizard"
                        type="object"
                        string="Reprocess"
                        class="btn-primary"
                        groups="restaurant_recipe_management.group_restaurant_recipe_manager"
                        invisible="state != 'error'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,error,reversed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="recipe_id" readonly="1"/>
                            <field name="operation_type" readonly="1"/>
                            <field name="processed_at" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                        </group>
                        <group>
                            <field name="pos_order_id" readonly="1"/>
                            <field name="pos_order_line_id" readonly="1"/>
                            <field name="sold_product_id" readonly="1"/>
                            <field name="sold_qty" readonly="1"/>
                            <field name="sold_uom_id" readonly="1"/>
                            <field name="recipe_cost_snapshot" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Locations">
                            <field name="source_location_id" readonly="1"/>
                            <field name="dest_location_id" readonly="1"/>
                            <field name="stock_picking_id" readonly="1"/>
                        </group>
                        <group string="Refund Linkage">
                            <field name="reversed_from_consumption_id" readonly="1"/>
                            <field name="reversal_ratio" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ingredient Lines">
                            <field name="move_line_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="ingredient_product_id"/>
                                    <field name="recipe_line_id"/>
                                    <field name="planned_qty"/>
                                    <field name="uom_id"/>
                                    <field name="unit_cost_snapshot"/>
                                    <field name="total_cost_snapshot"/>
                                    <field name="stock_move_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Error" invisible="not error_message">
                            <field name="error_message" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_recipe_consumption" model="ir.actions.act_window">
        <field name="name">Recipe Consumption Logs</field>
        <field name="res_model">restaurant.recipe.consumption</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
