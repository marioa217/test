<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_recipe_reprocess_wizard" model="ir.ui.view">
        <field name="name">restaurant.recipe.reprocess.wizard.form</field>
        <field name="model">restaurant.recipe.reprocess.wizard</field>
        <field name="arch" type="xml">
            <form string="Reprocess Recipe Consumption">
                <group>
                    <field name="pos_order_ids" invisible="1"/>
                    <field name="consumption_ids" invisible="1"/>
                    <field name="force_reprocess"/>
                    <field name="stop_on_error"/>
                </group>
                <footer>
                    <button name="action_reprocess" type="object" string="Reprocess" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rrm_reprocess_consumption_server" model="ir.actions.server">
        <field name="name">Reprocess Recipe Consumption</field>
        <field name="model_id" ref="model_restaurant_recipe_consumption"/>
        <field name="binding_model_id" ref="model_restaurant_recipe_consumption"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_rrm_reprocess_wizard()</field>
        <field name="group_ids" eval="[(4, ref('restaurant_recipe_management.group_restaurant_recipe_manager'))]"/>
    </record>

    <record id="action_rrm_reprocess_pos_order_server" model="ir.actions.server">
        <field name="name">Reprocess Recipe Consumption</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_rrm_reprocess_wizard()</field>
        <field name="group_ids" eval="[(4, ref('restaurant_recipe_management.group_restaurant_recipe_manager'))]"/>
    </record>

    <menuitem
        id="menu_restaurant_recipe_root"
        name="Recipe Management"
        parent="stock.menu_stock_root"
        sequence="45"
        groups="restaurant_recipe_management.group_restaurant_recipe_user"
    />

    <menuitem
        id="menu_restaurant_recipe"
        name="Recipes"
        parent="menu_restaurant_recipe_root"
        action="action_restaurant_recipe"
        sequence="10"
        groups="restaurant_recipe_management.group_restaurant_recipe_user"
    />

    <menuitem
        id="menu_restaurant_recipe_consumption"
        name="Recipe Consumption Logs"
        parent="menu_restaurant_recipe_root"
        action="action_restaurant_recipe_consumption"
        sequence="20"
        groups="restaurant_recipe_management.group_restaurant_recipe_user"
    />

    <menuitem
        id="menu_restaurant_recipe_pos_config"
        name="Recipe Configuration"
        parent="menu_restaurant_recipe_root"
        action="point_of_sale.action_pos_config_tree"
        sequence="30"
        groups="restaurant_recipe_management.group_restaurant_recipe_manager"
    />
</odoo>
