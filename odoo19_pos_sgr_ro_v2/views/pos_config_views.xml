<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_form_sgr_ro" model="ir.ui.view">
        <field name="name">pos.config.form.sgr.ro</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='tip_product_id']" position="after">
                <setting id="sgr_enabled" string="Romanian SGR Deposit" help="Automatically add SGR deposit lines in POS.">
                    <field name="sgr_enabled"/>
                    <div class="content-group" invisible="not sgr_enabled">
                        <div class="mt16">
                            <label for="sgr_deposit_product_id"/>
                            <field name="sgr_deposit_product_id" class="oe_inline"/>
                        </div>
                        <div class="mt16">
                            <label for="sgr_default_value"/>
                            <field name="sgr_default_value" class="oe_inline"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
