<odoo>
    <record id="view_pos_order_form_fiscal_bridge" model="ir.ui.view">
        <field name="name">pos.order.form.fiscal.bridge</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_debug_build_fiscal_text"
                        type="object"
                        string="Generate Fiscal Text"
                        class="btn-primary"/>
            </xpath>

            <xpath expr="//sheet/notebook" position="after">
                <group string="Fiscal Info">
                    <group>
                        <field name="fiscal_state"/>
                        <field name="fiscal_receipt_no"/>
                        <field name="fiscal_datetime"/>
                    </group>
                    <group>
                        <field name="fiscal_error_message"/>
                    </group>
                    <field name="fiscal_raw_response" widget="text"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
