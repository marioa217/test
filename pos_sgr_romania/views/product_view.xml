<odoo>
    <record id="product_template_sgr_form_inherit" model="ir.ui.view">
        <field name="name">product.template.sgr.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Setari SGR Romania">
                    <field name="tt_has_sgr" widget="boolean_toggle"/>
                    <group invisible="not tt_has_sgr">
                        <field name="tt_sgr_type"/>
                        <field name="tt_sgr_qty"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
