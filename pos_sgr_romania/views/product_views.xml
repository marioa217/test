<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add SGR fields to Product Template form -->
    <record id="view_product_template_sgr_form" model="ir.ui.view">
        <field name="name">product.template.sgr.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']//group[1]" position="after">
                <group string="SGR - Sistem Garanție-Returnare 🇷🇴" name="sgr_group">
                    <field name="has_sgr"
                           widget="boolean_toggle"
                           string="Activează SGR"/>
                    <field name="sgr_fee"
                           string="Taxă SGR (RON)"
                           invisible="not has_sgr"
                           required="has_sgr"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Add SGR column to Product list view -->
    <record id="view_product_template_sgr_list" model="ir.ui.view">
        <field name="name">product.template.sgr.list</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="has_sgr" string="SGR" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
