<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_config_sgr_form" model="ir.ui.view">
        <field name="name">pos.config.sgr.form</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="🇷🇴 SGR - Sistem Garanție-Returnare (OUG 74/2022)" name="sgr_config_group"
                       style="margin-top:16px; border-top: 2px solid #00913F; padding-top:12px;">
                    <field name="sgr_product_id"
                           string="Produs Taxă SGR"
                           options="{'no_create': True}"
                           placeholder="Selectează produsul Taxă SGR (0.50 RON)"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Dedicated list view for SGR config per POS -->
    <record id="view_pos_config_sgr_list" model="ir.ui.view">
        <field name="name">pos.config.sgr.list</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_config_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="sgr_product_id" string="Produs SGR" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Standalone SGR configuration action -->
    <record id="action_pos_config_sgr" model="ir.actions.act_window">
        <field name="name">Configurare SGR</field>
        <field name="res_model">pos.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configurați taxa SGR pentru punctele de vânzare
            </p>
        </field>
    </record>

    <!-- SGR menu under Point of Sale > Configuration -->
    <menuitem
        id="menu_pos_config_sgr"
        name="Configurare SGR"
        parent="point_of_sale.menu_point_config"
        action="action_pos_config_sgr"
        sequence="50"/>

</odoo>
