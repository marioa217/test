<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <!-- ── SGR Badge on Product Card ── -->
    <t t-name="pos_sgr_romania.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name')]" position="after">
            <t t-if="props.product.has_sgr">
                <div class="sgr-badge">
                    <span class="sgr-badge-icon">♻️</span>
                    <span class="sgr-badge-text">SGR</span>
                    <span class="sgr-badge-price">0.50 RON</span>
                </div>
            </t>
        </xpath>
    </t>

    <!-- ── SGR Indicator on Order Line ── -->
    <t t-name="pos_sgr_romania.Orderline" t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <xpath expr="//li[hasclass('orderline')]" position="attributes">
            <attribute name="t-att-class">
                {'sgr-orderline': props.line.is_sgr_line}
            </attribute>
        </xpath>
        <xpath expr="//div[hasclass('product-name')]" position="after">
            <t t-if="props.line.is_sgr_line">
                <span class="sgr-line-tag">♻️ SGR</span>
            </t>
        </xpath>
    </t>

</templates>
