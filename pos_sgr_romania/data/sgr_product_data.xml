<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- SGR Fee Product Category -->
        <record id="product_category_sgr" model="product.category">
            <field name="name">SGR - Garanție Returnare</field>
        </record>

        <!-- SGR Fee Product Template -->
        <record id="product_template_sgr_fee" model="product.template">
            <field name="name">Taxă SGR</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product_category_sgr"/>
            <field name="list_price">0.50</field>
            <field name="available_in_pos">True</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
            <field name="description_sale">Taxă Sistem Garanție-Returnare (SGR) conform OUG 74/2022</field>
            <field name="taxes_id" eval="[(5, 0, 0)]"/>
        </record>

        <!-- SGR Fee Product (product.product) -->
        <record id="product_product_sgr_fee" model="product.product">
            <field name="product_tmpl_id" ref="product_template_sgr_fee"/>
        </record>

    </data>
</odoo>
